# Copy to benchmarks/15turn/.env or export these values in your shell before running the benchmark.
# Do not commit real credentials, endpoints, workspace IDs, dataset IDs, or secrets.

AZURE_ENDPOINT=<your-azure-endpoint>
DEPLOYMENT_NAME=gpt-5.4
API_VERSION=2024-12-01-preview

FOUNDRY_PROJECT_ENDPOINT=<your-foundry-project-endpoint>
FOUNDRY_AGENT_NAME=your-foundry-agent-name
FOUNDRY_AGENT_VERSION=1

FABRIC_WORKSPACE_ID=your-fabric-workspace-id
DATASET_ID=your-power-bi-dataset-id