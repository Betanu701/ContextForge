    p.[<PRESCRIBER_IDENTIFIER_REDACTED>],
    p.[Prescriber Type],
    SUM(f.Tot_Clms) AS Tot_Clms
FROM cms_provider_drug_costs_star f
INNER JOIN cms_provider_dim_drug d
    ON f.Drug_Key = d.Drug_Key
INNER JOIN cms_provider_dim_provider p
    ON f.Provider_Key = p.Provider_Key
INNER JOIN cms_provider_dim_geography g
    ON f.Geo_Key = g.Geo_Key
INNER JOIN cms_provider_dim_year y
    ON f.Year = y.Year
WHERE g.Prscrbr_State_Abrvtn = 'TX'
  AND g.City = 'Houston'
  AND y.Year = 2021
  AND d.Gnrc_Name LIKE '%pril%'
GROUP BY
    p.Name,
    p.[<PRESCRIBER_IDENTIFIER_REDACTED>],
    p.[Prescriber Type]
ORDER BY SUM(f.Tot_Clms) DESC;
